# Production environment example — copy to .env and fill values
DJANGO_SECRET_KEY=replace-with-your-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=www.errandeye.com,api.errandeye.com,errandeye-production.up.railway.app

DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# CORS: allow the live frontend to call the API
CORS_ALLOWED_ORIGINS=https://www.errandeye.com

# Railway-compatible DB URL example (optional):
# DATABASE_URL=mysql://user:password@host:3306/dbname
